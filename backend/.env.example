# --- Server ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# --- Database (Supabase Postgres via Prisma) ---
# Pooled connection string (used by the running app)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nightlife_promoter?schema=public"
# Direct (non-pooled) connection string, used for migrations. On Supabase this is the
# "Direct connection" string from Project Settings > Database. Locally it's the same as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/nightlife_promoter?schema=public"

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=flyers

# --- AI (OpenAI) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Email (Resend) ---
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL="Nightlife Promoter <onboarding@resend.dev>"

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555550123

# --- Stripe Billing ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_ELITE=price_your_elite_price_id

# --- Seed script (optional overrides) ---
SEED_DEMO_EMAIL=demo@nightlifepromoter.ai
SEED_DEMO_PASSWORD=NightlifeDemo123!
